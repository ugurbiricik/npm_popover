<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
    <ResponsivePopover showHeader="false" placement="Left" >
        
        <FlexBox direction="Column" class="optionsContainer" id="panelContainer">
            
            <!-- Panel Header Section -->
            <FlexBox direction="Column">
                <FlexBox alignItems="Center" justifyContent="SpaceBetween" >
                    <Button icon="sap-icon://reset"  class="iconStyle" id="resetButton" press="resetClicked"/>
                    <Button icon="sap-icon://show"  class="iconStyle"/>
                    <Button icon="sap-icon://decline"  class="iconStyle"/>
                </FlexBox>
                <FlexBox alignItems="Center" justifyContent="SpaceBetween" >
                    <Button icon="sap-icon://action-settings"  class="iconStyle"/>
                    <Text text="Eye-Able Assistent" class="titleStyle" />
                    <Button icon="sap-icon://hint"  class="iconStyle"/>
                </FlexBox>
                
            </FlexBox>
              <!-- Sofortansicht Section -->
            <Panel id="sofortansichtpanel" expandable="false">
            <customData>
            <core:CustomData key="info" value="Sofortansicht hakkında detaylı bilgi" />
        </customData>
                <headerToolbar >
                    <OverflowToolbar>
                        <Button icon="sap-icon://action" class="iconStyle"/>
                        <Title text="Sofortansicht" class="titleStyle"/>
                    </OverflowToolbar>
                </headerToolbar>
             </Panel>
            
           <!-- Schriftgröße Section -->
            <Panel expandable="true" expanded="{configModel>/schriftgrosseExpanded}">
                <headerToolbar>
                    <OverflowToolbar press="togglePanel">
                        <Button icon="sap-icon://text" class="iconStyle"/>
                        <Title text="Schriftgröße" class="titleStyle"/>
                    </OverflowToolbar>
                </headerToolbar>
                <content>
                    <StepInput min="10" value="{configModel>/fontSize}" description="px" step="1"/>
                </content>
            </Panel>

            <!-- Kontrastmodus Section -->
            <Panel expandable="true" expanded="{configModel>/kontrastmodusExpanded}">
                <headerToolbar>
                    <OverflowToolbar press="togglePanel">
                        <Button icon="sap-icon://light-mode" class="iconStyle"/>
                        <Title text="Kontrastmodus" class="titleStyle"/>
                        <ToolbarSpacer />
                    </OverflowToolbar>
                </headerToolbar>
            </Panel>

            <!-- Blaufilter aktivieren Section -->
            <Panel expandable="true" expanded="{configModel>/blaufilterExpanded}">
                <headerToolbar>
                    <OverflowToolbar press="togglePanel">
                        <Button icon="sap-icon://lightbulb" class="iconStyle"/>
                        <Title text="Blaufilter aktivieren" class="titleStyle"/>
                    </OverflowToolbar>
                </headerToolbar>
                <content>
                    <Slider min="0" max="100" value="{configModel>/blueLight}" class="sliderStyle"/>
                </content>
            </Panel>
            
            <!-- Nachtmodus Section -->
            <Panel expandable="false">
                <headerToolbar>
                    <OverflowToolbar>
                        <Button icon="sap-icon://bed" class="iconStyle"/>
                        <Title text="Nachtmodus" class="titleStyle"/>
                        <ToolbarSpacer />
                    </OverflowToolbar>
                </headerToolbar>
            </Panel>
            
            <!-- Webseite vorlesen Section -->
            <Panel expandable="false">
                <headerToolbar>
                    <OverflowToolbar>
                        <Button icon="sap-icon://microphone" class="iconStyle"/>
                        <Title text="Webseite vorlesen" class="titleStyle"/>
                    </OverflowToolbar>
                </headerToolbar>
            </Panel>
            
            <!-- Tab Navigation Section -->
            <Panel expandable="false">
                <headerToolbar>
                    <OverflowToolbar>
                        <Button icon="sap-icon://keyboard-and-mouse" class="iconStyle"/>
                        <Title text="Tab Navigation" class="titleStyle"/>
                    </OverflowToolbar>
                </headerToolbar>
            </Panel>
            
            <!-- Farbschwäche Section -->
            <Panel expandable="false">
                <headerToolbar>
                    <OverflowToolbar>
                        <Button icon="sap-icon://palette" class="iconStyle"/>
                        <Title text="Farbschwäche" class="titleStyle"/>
                    </OverflowToolbar>
                </headerToolbar>
            </Panel>
            
            <!-- Bilder ausblenden Section -->
            <Panel expandable="false">
                <headerToolbar>
                    <OverflowToolbar>
                        <Button icon="sap-icon://hide" class="iconStyle"/>
                        <Title text="Bilder ausblenden" class="titleStyle"/>
                    </OverflowToolbar>
                </headerToolbar>
            </Panel>
            
            <!-- Mehr Funktionen Section -->
            <Panel expandable="false">
                <headerToolbar>
                    <OverflowToolbar>
                        <Button icon="sap-icon://add" class="iconStyle"/>
                        <Title text="Mehr Funktionen" class="titleStyle"/>
                    </OverflowToolbar>
                </headerToolbar>
            </Panel>
            
            <!-- Alles zurücksetzen Section -->
            <Panel expandable="false">
                <headerToolbar>
                    <OverflowToolbar>
                        <Button icon="sap-icon://refresh" class="iconStyle" press="clickBtn"/>
                        <Title text="Alles zurücksetzen" class="titleStyle"/>
                    </OverflowToolbar>
                </headerToolbar>
            </Panel>
        </FlexBox>
    </ResponsivePopover>
</core:FragmentDefinition>
